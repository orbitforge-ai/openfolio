{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PDF Forge",
  "version": "0.1.0",
  "identifier": "com.pdf-forge.editor",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PDF Forge",
        "width": 1360,
        "height": 900,
        "minWidth": 1040,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
